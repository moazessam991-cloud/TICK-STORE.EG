PORT=38471
# Optional: override bundled site (default is ./public/index.html in this repo)
# TICK_HTML=/absolute/path/to/site.html
TICK_DB_PATH=/absolute/path/to/tick.sqlite
TICK_JWT_SECRET=use-a-long-random-string-in-production
TICK_PW_SALT=TICK_CAIRO_2026_SALT_MZ
TICK_ADMIN_PASSWORD=tick.2026

# Twilio WhatsApp (https://console.twilio.com/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Your Twilio WhatsApp sender, e.g. whatsapp:+14155238886 (sandbox) or whatsapp:+1xxxxxxxxxx (approved)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: your store WhatsApp (Egypt 01… or +20…) — receive a WhatsApp when /api/public/order succeeds
# TWILIO_ORDER_NOTIFY_TO=+201000000000

# Public base URL of this app (no path) — required for webhook signature verification in production
# TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# Behind nginx/load balancer: set TRUST_PROXY=1 and TWILIO_WEBHOOK_BASE_URL to the public URL
# TRUST_PROXY=1

# Local webhook testing only — never enable in production
# TWILIO_SKIP_WEBHOOK_VERIFY=1
